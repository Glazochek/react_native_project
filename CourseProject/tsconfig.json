{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "#design": ["src/shared/design/index.ts"],
      "#design/*": ["src/shared/design/*/index.ts"],
      "#shared/*": ["src/shared/*/index.ts"],
      "#features/*": ["src/features/*/index.ts"]
    }
  },
  "include": [
    "**/*.js",
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["**/__tests__/**", "jest.setup.ts"]
}
