{
  "name": "astrowatch",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "imports": {
    "#design": "./src/shared/design/index.ts",
    "#design/*": "./src/shared/design/*/index.ts",
    "#shared/*": "./src/shared/*/index.ts"
  },
  "scripts": {
    "lint": "npm run lint-typecheck && npm run lint-eslint && npm run lint-prettier && npm run lint-knip",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint .",
    "lint-prettier": "prettier --check .",
    "lint-knip": "knip",
    "start": "expo start --clear"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/drawer": "^7.5.0",
    "expo": "^55.0.0",
    "expo-constants": "~55.0.16",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.16",
    "expo-screen-orientation": "~55.0.16",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@christopherjbaker/eslint-config": "^3.1.4",
    "@types/react": "~19.2.10",
    "eslint": "^9.39.4",
    "eslint-plugin-expo": "^1.0.3",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  }
}
