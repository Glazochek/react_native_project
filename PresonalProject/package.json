{
  "name": "nomnom",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start --lan",
    "lint": "npm run lint-typecheck && npm run lint-eslint && npm run lint-prettier",
    "lint-typecheck": "tsc --noEmit",
    "lint-eslint": "eslint App.tsx src babel.config.js eslint.config.js --ignore-pattern '**/__tests__/**'",
    "lint-prettier": "prettier --check .",
    "test": "jest --runInBand --ci --no-watchman"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "expo": "^56.0.0",
    "expo-font": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@react-native/jest-preset": "^0.85.3",
    "@types/react": "~19.2.10",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "jest": {
    "preset": "@react-native/jest-preset",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "testMatch": [
      "<rootDir>/src/shared/design/components/__tests__/**/*.test.tsx"
    ],
    "moduleNameMapper": {
      "^react-native-svg$": "<rootDir>/__mocks__/react-native-svg.js"
    }
  }
}
